# Server
PORT=5000
NODE_ENV=development

# Ma'lumotlar bazasi (maxfiy)
MONGO_URI=mongodb://127.0.0.1:27017/edunext_ai

# Supabase (Auth + profiles). Dashboard: Dashboard → Authentication → Providers → Email (yoqilgan bo‘lishi kerak).
# Anon key brauzerda chiqadi — RLS bilan himoyalang.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# Eski Passport Google (agar alohida ishlatilsa)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=o_zgartiring

# Groq AI (faqat backend .env da — kodga yozmaymiz)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ixtiyoriy: boshqa Google AI (onboarding-controller)
GEMINI_API_KEY=

# Frontend → API tugmasini boshqacha domen uchun (PDF/slotsiz = nisbiy `/api`).
# Misol (statik SPA + backend alohida): https://api.sizning-domen.com
PUBLIC_API_BASE_URL=

# CORS (vergul bilan bir necha origin): STATIC sayt boshqa domen bo'lsa kerak bo'ladi.
# Bo'sh = CORS middleware qo'shilmaydi (bir manbada host qilingan holat).
# Misol: https://app.example.com,https://www.example.com
CORS_ORIGIN=
